 void IN_WaitAndProcessEvents()
 {
     SDL_Event event;
+#ifdef Z6S_TARGET
+    /* Direct evdev input cannot wake SDL_WaitEvent.  Short polling also keeps
+       the threadless ALSA mixer progressing on menu and wait screens. */
+    for(;;)
+    {
+        Z6S_InputPump();
+        Mix_Z6S_Pump();
+        if(SDL_PollEvent(&event))
+        {
+            do
+            {
+                processEvent(&event);
+            }
+            while(SDL_PollEvent(&event));
+            return;
+        }
+        SDL_Delay(5);
+    }
+#else
     if(!SDL_WaitEvent(&event)) return;
     do
     {
         processEvent(&event);
     }
     while(SDL_PollEvent(&event));
+#endif
 }
 
