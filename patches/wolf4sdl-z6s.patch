@@ -86,6 +86,34 @@ void	VL_Shutdown (void)
 }
 
 
+#ifdef Z6S_TARGET
+/* The Z6S scanout interprets the unused high byte of each 32-bit pixel as
+   alpha. SDL 1.2's palette blitter leaves it at zero, producing a black LCD
+   even though a framebuffer dump contains the correct RGB image. */
+void VL_Z6SForceOpaque(void)
+{
+    static int enabled = -1;
+    if(enabled < 0)
+    {
+        const char *value = getenv("Z6S_FORCE_OPAQUE");
+        enabled = !value || strcmp(value, "0") != 0 ? 1 : 0;
+    }
+    if(!enabled || !screen || screen->format->BytesPerPixel != 4)
+        return;
+
+    if(SDL_MUSTLOCK(screen) && SDL_LockSurface(screen) < 0)
+        return;
+    for(int y = 0; y < screen->h; ++y)
+    {
+        Uint32 *row = (Uint32 *)((Uint8 *)screen->pixels + y * screen->pitch);
+        for(int x = 0; x < screen->w; ++x)
+            row[x] |= 0xff000000U;
+    }
+    if(SDL_MUSTLOCK(screen))
+        SDL_UnlockSurface(screen);
+}
+#endif
+
