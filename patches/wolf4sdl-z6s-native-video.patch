 #ifdef Z6S_TARGET
+static Uint16 *z6sXMap;
+static Uint16 *z6sYMap;
+static Uint32 *z6sFrame;
+static int z6sMapWidth;
+static int z6sMapHeight;
+static int z6sSourceWidth;
+static int z6sSourceHeight;
+
 /* The Z6S scanout interprets the unused high byte of each 32-bit pixel as
    alpha. SDL 1.2's palette blitter leaves it at zero, producing a black LCD
    even though a framebuffer dump contains the correct RGB image. */
@@ -112,6 +120,86 @@
     if(SDL_MUSTLOCK(screen))
         SDL_UnlockSurface(screen);
 }
+
+/* Keep the LCD in its native mode and scale the lightweight 8-bit game
+   surface into one complete opaque 32-bit frame.  Coordinate maps are built
+   only when a size changes, avoiding divisions in the per-pixel hot path. */
+void VL_Z6SPresent(SDL_Surface *source)
+{
+    if(!source || !screen)
+        return;
+
+    const int dstWidth = screen->w;
+    const int dstHeight = screen->h;
+    if(source->format->BytesPerPixel != 1 ||
+       screen->format->BytesPerPixel != 4 ||
+       dstWidth <= 0 || dstHeight <= 0)
+    {
+        SDL_BlitSurface(source, NULL, screen, NULL);
+        VL_Z6SForceOpaque();
+        SDL_Flip(screen);
+        return;
+    }
+
+    if(z6sMapWidth != dstWidth || z6sMapHeight != dstHeight ||
+       z6sSourceWidth != source->w || z6sSourceHeight != source->h)
+    {
+        Uint16 *newX = (Uint16 *) realloc(z6sXMap,
+                                          dstWidth * sizeof(Uint16));
+        if(!newX) return;
+        z6sXMap = newX;
+
+        Uint16 *newY = (Uint16 *) realloc(z6sYMap,
+                                          dstHeight * sizeof(Uint16));
+        if(!newY) return;
+        z6sYMap = newY;
+
+        Uint32 *newFrame = (Uint32 *) realloc(z6sFrame,
+                              dstWidth * dstHeight * sizeof(Uint32));
+        if(!newFrame) return;
+        z6sFrame = newFrame;
+
+        for(int x = 0; x < dstWidth; ++x)
+            z6sXMap[x] = (Uint16) ((x * source->w) / dstWidth);
+        for(int y = 0; y < dstHeight; ++y)
+            z6sYMap[y] = (Uint16) ((y * source->h) / dstHeight);
+
+        z6sMapWidth = dstWidth;
+        z6sMapHeight = dstHeight;
+        z6sSourceWidth = source->w;
+        z6sSourceHeight = source->h;
+        printf("Z6S video scaler: %dx%d logical -> %dx%dx32 native\n",
+               source->w, source->h, dstWidth, dstHeight);
+        fflush(stdout);
+    }
+
+    Uint32 palette[256];
+    for(int i = 0; i < 256; ++i)
+        palette[i] = SDL_MapRGB(screen->format, curpal[i].r, curpal[i].g,
+                               curpal[i].b) | 0xff000000U;
+
+    if(SDL_MUSTLOCK(source) && SDL_LockSurface(source) < 0)
+        return;
+    for(int y = 0; y < dstHeight; ++y)
+    {
+        const Uint8 *src = (const Uint8 *) source->pixels +
+                           z6sYMap[y] * source->pitch;
+        Uint32 *dst = z6sFrame + y * dstWidth;
+        for(int x = 0; x < dstWidth; ++x)
+            dst[x] = palette[src[z6sXMap[x]]];
+    }
+    if(SDL_MUSTLOCK(source))
+        SDL_UnlockSurface(source);
+
+    if(SDL_MUSTLOCK(screen) && SDL_LockSurface(screen) < 0)
+        return;
+    for(int y = 0; y < dstHeight; ++y)
+        memcpy((Uint8 *) screen->pixels + y * screen->pitch,
+               z6sFrame + y * dstWidth, dstWidth * sizeof(Uint32));
+    if(SDL_MUSTLOCK(screen))
+        SDL_UnlockSurface(screen);
+    SDL_Flip(screen);
+}
 #endif
 
